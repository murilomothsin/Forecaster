<div class="mt-6">
  <h3 class="text-lg font-semibold mb-3">5-Day Forecast</h3>
  <% daily_forecasts.each do |day| %>
    <div class="mb-4">
      <p class="text-sm font-medium text-gray-600 mb-2"><%= day.formatted_date %></p>
      <div class="overflow-x-auto pb-2 -mx-5 px-5">
        <div class="flex gap-3 w-max">
          <% day.entries.each do |entry| %>
            <%= render "home/forecast_entry", entry: entry %>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>
