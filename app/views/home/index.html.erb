<div class="w-full max-w-lg mx-auto">
  <h1 class="font-bold text-4xl mb-8">Weather Forecast</h1>

  <%= form_with url: root_path, method: :get, data: { turbo_frame: "forecast_result", controller: "search-toggle" } do |f| %>
    <div class="flex gap-4 mb-4">
      <label class="flex items-center gap-2 cursor-pointer">
        <%= f.radio_button :search_mode, "zip",
              checked: params[:search_mode] != "city",
              data: { action: "search-toggle#toggle" },
              class: "accent-blue-600" %>
        <span class="text-sm font-medium text-gray-700">Zip Code</span>
      </label>
      <label class="flex items-center gap-2 cursor-pointer">
        <%= f.radio_button :search_mode, "city",
              checked: params[:search_mode] == "city",
              data: { action: "search-toggle#toggle" },
              class: "accent-blue-600" %>
        <span class="text-sm font-medium text-gray-700">City</span>
      </label>
    </div>

    <div data-search-toggle-target="zipFields">
      <div class="mb-4">
        <%= f.label :zip_code, "Zip Code", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :zip_code, value: params[:zip_code], placeholder: "e.g. 10001",
              class: "w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" %>
      </div>
    </div>

    <div data-search-toggle-target="cityFields">
      <div class="mb-4">
        <%= f.label :city, "City", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :city, value: params[:city], placeholder: "e.g. London",
              class: "w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" %>
      </div>
    </div>

    <div class="mb-6">
      <%= f.label :country, "Country", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :country,
            ApplicationHelper::COUNTRY_OPTIONS,
            { selected: params[:country] || "US" },
            class: "w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" %>
    </div>

    <%= f.submit "Get Forecast", class: "w-full bg-blue-600 text-white font-medium py-2 px-4 rounded-md hover:bg-blue-700 cursor-pointer" %>
  <% end %>

  <%= turbo_frame_tag "forecast_result" do %>
    <% if @error %>
      <div class="mt-6 p-4 bg-red-50 border border-red-200 rounded-md text-red-700">
        <p><%= @error %></p>
      </div>
    <% elsif @weather %>
      <%= render "home/current_weather", weather: @weather %>
      <%= render "home/extended_forecast", daily_forecasts: @weather.daily_forecasts if @weather.extended_forecast? %>
    <% end %>
  <% end %>
</div>
